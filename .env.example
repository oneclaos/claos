# ═══════════════════════════════════════════════════════════════════════════════
# Claos Dashboard — Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env.local and configure. Most settings have sensible defaults.
# 
# QUICK START (1-click Docker):
#   1. cp .env.example .env.local
#   2. docker compose up -d
#   3. Open http://localhost:3006 and set your password in the wizard
# ═══════════════════════════════════════════════════════════════════════════════

# ── Authentication ───────────────────────────────────────────────────────────
# On first run, you'll set your password via the web wizard.
# The hash is stored in DATA_DIR/config.json automatically.
#
# To pre-configure (skip wizard):
# CLAOS_PASSWORD_HASH=<bcrypt hash>
# Generate: node -e "require('bcrypt').hash('your-password', 12).then(console.log)"

# ── CSRF Protection (optional) ───────────────────────────────────────────────
# Auto-generated on first run if not set. Set for stability across restarts.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CSRF_SECRET=

# ── Gateway Discovery ────────────────────────────────────────────────────────
# Claos auto-discovers Clawdbot gateways on localhost ports 18700-18850.
# Customize the port range if your agents run elsewhere:
# GATEWAY_PORT_START=18700
# GATEWAY_PORT_END=18850
#
# For remote gateways or manual configuration, use GATEWAYS JSON:
# GATEWAYS=[{"id":"main","name":"Main Agent","url":"ws://localhost:18789","token":"your-token"}]
#
# Note: Auto-discovered gateways without tokens require pairing via the UI.

# ── File Manager Security ────────────────────────────────────────────────────
# Directories the file manager can access (comma-separated).
# Default: /home,/srv,/var/www,/tmp/claos-data
#
# System user homes (root, ubuntu, admin, etc.) are always blocked.
# ALLOWED_BASE_PATHS=/home/myuser,/srv/projects

# ── Data Storage ─────────────────────────────────────────────────────────────
# Where to store sessions, config, audit logs.
# Default: ~/.claos (or /data in Docker)
# WARNING: Do NOT use /tmp — data is lost on reboot!
# DATA_DIR=/home/youruser/.claos

# ── Session Security ─────────────────────────────────────────────────────────
# Bind sessions to IP + User-Agent (prevents session hijacking)
# Set to false if users have dynamic IPs or switch browsers
# Default: false (permissive for dev, enable in production)
# STRICT_SESSION_BINDING=true

# ── Network ──────────────────────────────────────────────────────────────────
# NODE_ENV=production
# PORT=3006
# HOSTNAME=0.0.0.0
#
# Force HTTPS redirect (when behind a reverse proxy)
# FORCE_HTTPS=true

# ── Docker User/Group ────────────────────────────────────────────────────────
# Required when container needs to access /home files as your user.
# Run `id -u` and `id -g` to get your values.
# UID=1000
# GID=1000

# ── Terminal Sessions ────────────────────────────────────────────────────────
# Max concurrent terminal sessions
# Default: 20 (no practical limit for personal use)
TERMINAL_MAX_SESSIONS=20

# Session timeout in milliseconds (inactive sessions are cleaned up)
# Default: 1800000 (30 minutes)
# TERMINAL_SESSION_TIMEOUT=1800000

# Terminal user and home directory
# Default: current user and $HOME
# TERMINAL_USER=clawd
# TERMINAL_HOME=/home/clawd

# ── Backup (Optional) ────────────────────────────────────────────────────────
# S3-compatible backup configuration (use with docker-compose --profile backup)
# BACKUP_BUCKET=my-bucket
# BACKUP_ENDPOINT=https://s3.amazonaws.com
# BACKUP_REGION=us-east-1
# BACKUP_RETENTION_DAYS=30
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
